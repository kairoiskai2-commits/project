{
  "name": "Post",
  "type": "object",
  "properties": {
    "author_email": {
      "type": "string"
    },
    "author_name": {
      "type": "string"
    },
    "author_avatar": {
      "type": "string"
    },
    "content": {
      "type": "string"
    },
    "image_url": {
      "type": "string"
    },
    "place_name": {
      "type": "string"
    },
    "place_id": {
      "type": "string"
    },
    "likes_count": {
      "type": "number",
      "default": 0
    },
    "comments_count": {
      "type": "number",
      "default": 0
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "type": {
      "type": "string",
      "enum": [
        "photo",
        "memory",
        "review",
        "tip"
      ],
      "default": "photo"
    }
  },
  "required": [
    "author_email",
    "content"
  ]
}