# =================================================================
# FREE APIs (No Setup Required - Work Out of the Box!)
# =================================================================
# These services are completely free and work without any API keys

# ✅ Wikipedia API - MediaWiki REST API (Free)
# No configuration needed - automatically works!

# ✅ Weather API - Open-Meteo (Free)
# No configuration needed - automatically works!

# ✅ Geocoding API - OpenStreetMap Nominatim (Free)
# No configuration needed - automatically works!

# ✅ Currency API - ExchangeRate-API (Free)
# No configuration needed - automatically works!

# ✅ AI Chat - Hugging Face Inference API (Free)
# No configuration needed - automatically works!

# ✅ Maps Search API - OpenStreetMap Nominatim (Free)
# No configuration needed - automatically works!

# ✅ Wikipedia Auto-Place Creator (Free)
# No configuration needed - automatically works!

# ✅ AI Trip Planner - Hugging Face (Free)
# No configuration needed - automatically works!

# =================================================================
# Optional Enhanced APIs (Paid/Free Tier)
# =================================================================

# Supabase Configuration (Free tier available)
# Get from: https://supabase.com/dashboard/projects
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI API (Paid - better AI responses)
# Get from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-your_openai_key_here

# Groq API (used by AskAI)
# Get from: https://console.groq.com/keys
# For Cloudflare Pages, set GROQ_API_KEY as a runtime environment variable.
# For local Vite-only testing, VITE_GROQ_API_KEY also works but is exposed to the browser.
GROQ_API_KEY=your-groq-api-key
VITE_GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Pexels Images (Free tier: 200 requests/hour)
# Get from: https://www.pexels.com/api/
VITE_PEXELS_API_KEY=your_pexels_api_key_here

# Google Maps API (Free tier: $200/month credit)
# Get from: https://console.cloud.google.com/apis/credentials
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_key

# =================================================================
# Legacy/Optional APIs
# =================================================================

# Unsplash API (Free tier available)
VITE_UNSPLASH_API_KEY=your-unsplash-api-key

# Pixabay API (Free)
VITE_PIXABAY_API_KEY=your-pixabay-api-key

# OpenWeather API (Free tier available)
VITE_OPENWEATHER_API_KEY=your-openweather-api-key

# Custom Backend API (if you have a separate backend)
# VITE_API_BASE_URL=http://localhost:3001/api

# =================================================================
# How to Use:
# =================================================================
# 1. Copy this file to .env.local for local development
# 2. For production deployment, set these in your hosting platform:
#    - Cloudflare Pages: Dashboard > Pages > Settings > Environment variables
#    - Vercel: Dashboard > Project > Settings > Environment Variables
#    - Netlify: Dashboard > Site settings > Environment variables
#
# 3. FREE APIs work immediately - no setup needed!
# 4. Add paid API keys only for enhanced features
