# Frontend Environment Variables

# Supabase Configuration
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# OpenAI API Key (for client-side features if needed)
VITE_OPENAI_API_KEY=your-openai-api-key

# External API Keys (if used client-side)
VITE_UNSPLASH_API_KEY=your-unsplash-api-key
VITE_PIXABAY_API_KEY=your-pixabay-api-key
VITE_OPENWEATHER_API_KEY=your-openweather-api-key

# Legacy API URL (if still using custom backend)
# VITE_API_BASE_URL=http://localhost:3001/api
